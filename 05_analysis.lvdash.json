{
  "datasets": [
    {
      "name": "9ff04d28",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT\n",
        "    COUNT(*) AS total_stations,\n",
        "    SUM(CASE WHEN station_status = 'empty'  THEN 1 ELSE 0 END) AS currently_empty,\n",
        "    SUM(CASE WHEN station_status = 'full'   THEN 1 ELSE 0 END) AS currently_full,\n",
        "    SUM(CASE WHEN station_status = 'locked' THEN 1 ELSE 0 END) AS currently_locked,\n",
        "    ROUND(AVG(occupancy_rate), 3) AS avg_network_occupancy\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "ed12ba0b",
      "displayName": "Risk Distribution",
      "queryLines": [
        "SELECT\n",
        "    availability_risk_band,\n",
        "    COUNT(*) AS station_count,\n",
        "    ROUND(AVG(availability_risk_score), 3) AS avg_risk_score\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "GROUP BY availability_risk_band\n",
        "ORDER BY\n",
        "    CASE availability_risk_band\n",
        "        WHEN 'critical' THEN 1\n",
        "        WHEN 'high'     THEN 2\n",
        "        WHEN 'medium'   THEN 3\n",
        "        WHEN 'low'      THEN 4\n",
        "    END"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "f8584ddd",
      "displayName": "Station Aggregated",
      "queryLines": [
        "SELECT\n",
        "    bikepoint_id,\n",
        "    station_name,\n",
        "    place_type,\n",
        "    latitude,\n",
        "    longitude,\n",
        "    nb_docks,\n",
        "    capacity_category,\n",
        "    snapshot_count,\n",
        "    availability_risk_score,\n",
        "    availability_risk_band,\n",
        "    reliability_score,\n",
        "    investment_priority_rank,\n",
        "    pct_time_empty,\n",
        "    pct_time_full,\n",
        "    pct_time_low_bikes,\n",
        "    pct_time_low_docks,\n",
        "    pct_time_locked,\n",
        "    broken_dock_rate,\n",
        "    avg_occupancy_rate,\n",
        "    occupancy_volatility,\n",
        "    avg_ebike_share,\n",
        "    CASE\n",
        "        WHEN pct_time_locked      >= 0.20 THEN 'needs_maintenance_locked'\n",
        "        WHEN broken_dock_rate     >= 0.20 THEN 'needs_maintenance_broken'\n",
        "        WHEN pct_time_empty       >= 0.30 THEN 'needs_more_bikes'\n",
        "        WHEN pct_time_full        >= 0.30 THEN 'needs_more_docks'\n",
        "        WHEN pct_time_low_bikes   >= 0.30 THEN 'rebalance_supply'\n",
        "        WHEN pct_time_low_docks   >= 0.30 THEN 'rebalance_capacity'\n",
        "        ELSE 'healthy'\n",
        "    END AS intervention_category\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "beed461a",
      "displayName": "Current Status",
      "queryLines": [
        "SELECT\n",
        "    bikepoint_id,\n",
        "    station_name,\n",
        "    latitude,\n",
        "    longitude,\n",
        "    nb_bikes,\n",
        "    nb_empty_docks,\n",
        "    nb_docks,\n",
        "    station_status,\n",
        "    capacity_category,\n",
        "    occupancy_rate,\n",
        "    ingestion_ts\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "23ed31fe",
      "displayName": "Status Distribution",
      "queryLines": [
        "SELECT\n",
        "    station_status,\n",
        "    COUNT(*) AS station_count\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status\n",
        "GROUP BY station_status\n",
        "ORDER BY station_count DESC"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "da3b44c3",
      "displayName": "Least Reliable Stations",
      "queryLines": [
        "SELECT\n",
        "    investment_priority_rank,\n",
        "    station_name,\n",
        "    capacity_category,\n",
        "    availability_risk_band,\n",
        "    ROUND(availability_risk_score, 2) AS availability_risk_score,\n",
        "    ROUND(pct_time_empty, 2) AS pct_time_empty,\n",
        "    ROUND(pct_time_full, 2) AS pct_time_full,\n",
        "    ROUND(broken_dock_rate, 2) AS broken_dock_rate,\n",
        "    ROUND(pct_time_low_bikes, 2) AS pct_time_low_bikes,\n",
        "    ROUND(pct_time_low_docks, 2) AS pct_time_low_docks,\n",
        "    snapshot_count\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "ORDER BY investment_priority_rank ASC"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "69eb78fc",
      "displayName": "Top10 Risk Drivers",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    ROUND(pct_time_empty, 2) AS pct_time_empty,\n",
        "    ROUND(pct_time_full, 2) AS pct_time_full,\n",
        "    ROUND(broken_dock_rate, 2) AS broken_dock_rate,\n",
        "    ROUND(pct_time_low_bikes, 2) AS pct_time_low_bikes,\n",
        "    ROUND(pct_time_low_docks, 2) AS pct_time_low_docks,\n",
        "    ROUND(availability_risk_score, 2) AS availability_risk_score,\n",
        "    investment_priority_rank\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "ORDER BY investment_priority_rank ASC\n",
        "LIMIT 10"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "ea1a4a07",
      "displayName": "Current Empty Station",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    nb_bikes\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status\n",
        "WHERE station_status = 'empty'\n",
        "ORDER BY station_name"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "19624e49",
      "displayName": "Current Full Station",
      "queryLines": [
        "SELECT\n",
        "    ROW_NUMBER() OVER (ORDER BY station_name) AS number,\n",
        "    station_name,\n",
        "    nb_bikes,\n",
        "    nb_empty_docks\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status\n",
        "WHERE station_status = 'full'\n",
        "ORDER BY number"
      ]
    },
    {
      "name": "7ee8dfb6",
      "displayName": "Current Locked Station",
      "queryLines": [
        "SELECT\n",
        "    ROW_NUMBER() OVER (ORDER BY station_name) AS number,\n",
        "    station_name,\n",
        "    nb_bikes,\n",
        "    nb_empty_docks,\n",
        "    nb_docks,\n",
        "    station_status\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status\n",
        "WHERE station_status = 'locked'\n",
        "ORDER BY number"
      ]
    },
    {
      "name": "fd6b1b3f",
      "displayName": "Weekday vs Weekend Occupancy",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    ROUND(weekday_avg_occupancy, 2) AS weekday_avg_occupancy,\n",
        "    ROUND(weekend_avg_occupancy, 2) AS weekend_avg_occupancy,\n",
        "    ROUND(weekday_avg_occupancy - weekend_avg_occupancy, 2) AS weekday_weekend_gap,\n",
        "    availability_risk_band,\n",
        "    capacity_category\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "WHERE weekday_avg_occupancy IS NOT NULL\n",
        "  AND weekend_avg_occupancy IS NOT NULL\n",
        "ORDER BY ABS(weekday_avg_occupancy - weekend_avg_occupancy) DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "c3aa7923",
      "displayName": "Morning Peak vs Evening Peak Occupancy",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    ROUND(morning_peak_avg_occupancy, 2) AS morning_peak_avg_occupancy,\n",
        "    ROUND(evening_peak_avg_occupancy, 2) AS evening_peak_avg_occupancy,\n",
        "    ROUND(morning_peak_avg_occupancy - evening_peak_avg_occupancy, 2) AS peak_gap,\n",
        "    availability_risk_band,\n",
        "    capacity_category\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "WHERE morning_peak_avg_occupancy IS NOT NULL\n",
        "  AND evening_peak_avg_occupancy IS NOT NULL\n",
        "ORDER BY ABS(morning_peak_avg_occupancy - evening_peak_avg_occupancy) DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "ee17ff22",
      "displayName": "Station Reliability Leaderboard",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    capacity_category,\n",
        "    ROUND(reliability_score, 2) AS reliability_score,\n",
        "    ROUND(availability_risk_score, 2) AS availability_risk_score,\n",
        "    ROUND(pct_time_empty, 2) AS pct_time_empty,\n",
        "    ROUND(pct_time_full, 2) AS pct_time_full,\n",
        "    ROUND(broken_dock_rate, 2) AS broken_dock_rate,\n",
        "    snapshot_count\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "ORDER BY reliability_score DESC"
      ],
      "catalog": "workspace",
      "schema": "bikepoint"
    },
    {
      "name": "ff4e46eb",
      "displayName": "Underutilised Stations",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    nb_docks,\n",
        "    capacity_category,\n",
        "    ROUND(avg_occupancy_rate, 2) AS avg_occupancy_rate,\n",
        "    ROUND(pct_time_empty, 2) AS pct_time_empty,\n",
        "    ROUND(pct_time_full, 2) AS pct_time_full,\n",
        "    ROUND(availability_risk_score, 2) AS availability_risk_score\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "WHERE avg_occupancy_rate < 0.20\n",
        "ORDER BY avg_occupancy_rate ASC"
      ]
    },
    {
      "name": "e0164e75",
      "displayName": "Current Status vs Historical Risk",
      "queryLines": [
        "SELECT\n",
        "    s.station_status,\n",
        "    m.availability_risk_band,\n",
        "    COUNT(*) AS station_count\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_current_status s\n",
        "JOIN workspace.bikepoint.gold_bikepoint_station_aggregated_metrics m\n",
        "    ON s.bikepoint_id = m.bikepoint_id\n",
        "GROUP BY\n",
        "    s.station_status,\n",
        "    m.availability_risk_band\n",
        "ORDER BY\n",
        "    CASE s.station_status\n",
        "        WHEN 'empty' THEN 1\n",
        "        WHEN 'full' THEN 2\n",
        "        WHEN 'locked' THEN 3\n",
        "        WHEN 'low_bikes' THEN 4\n",
        "        WHEN 'low_docks' THEN 5\n",
        "        WHEN 'normal' THEN 6\n",
        "        ELSE 7\n",
        "    END,\n",
        "    CASE m.availability_risk_band\n",
        "        WHEN 'critical' THEN 1\n",
        "        WHEN 'high' THEN 2\n",
        "        WHEN 'medium' THEN 3\n",
        "        WHEN 'low' THEN 4\n",
        "        ELSE 5\n",
        "    END"
      ]
    },
    {
      "name": "45b55d15",
      "displayName": "Underused vs Overloaded Stations",
      "queryLines": [
        "SELECT\n",
        "    station_name,\n",
        "    nb_docks,\n",
        "    capacity_category,\n",
        "    ROUND(avg_occupancy_rate, 2) AS avg_occupancy_rate,\n",
        "    ROUND(pct_time_empty, 2) AS pct_time_empty,\n",
        "    ROUND(pct_time_full, 2) AS pct_time_full,\n",
        "    ROUND(availability_risk_score, 2) AS availability_risk_score,\n",
        "    availability_risk_band,\n",
        "    investment_priority_rank,\n",
        "\n",
        "    CASE\n",
        "        WHEN avg_occupancy_rate >= 0.80 THEN 'overloaded'\n",
        "        WHEN avg_occupancy_rate <= 0.20 THEN 'underused'\n",
        "        ELSE 'balanced'\n",
        "    END AS utilisation_category\n",
        "\n",
        "FROM workspace.bikepoint.gold_bikepoint_station_aggregated_metrics\n",
        "\n",
        "WHERE avg_occupancy_rate IS NOT NULL"
      ]
    }
  ],
